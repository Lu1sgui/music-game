# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-secret"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Weekly cycle schedule (cron syntax, all times UTC) ──────────────────────
# Colombia is UTC-5 (no daylight saving)
#
# Monday   00:00 COT = Monday   05:00 UTC → reveal + archive + create new cycle
# Tuesday  00:00 COT = Tuesday  05:00 UTC → open submissions
# Friday   17:00 COT = Friday   22:00 UTC → close submissions (GM scores Sat+Sun)
#
CYCLE_REVEAL_CRON="0 5 * * 1"
CYCLE_OPEN_CRON="0 5 * * 2"
CYCLE_CLOSE_CRON="0 22 * * 5"
