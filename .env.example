# ─── Database ────────────────────────────────────────────────────────────────
# MySQL connection string for Prisma
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/music_game"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# At least 32 random characters — generate with: openssl rand -base64 32
JWT_SECRET="replace-this-with-a-long-random-secret"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Cycle schedule (UTC) ─────────────────────────────────────────────────────
# These are used by the cron scheduler in lib/cron.ts
# Default: cycles open Monday 00:00 UTC, close Thursday 23:59 UTC, reveal Friday 18:00 UTC
CYCLE_OPEN_CRON="0 0 * * 1"
CYCLE_CLOSE_CRON="59 23 * * 4"
CYCLE_REVEAL_CRON="0 18 * * 5"
